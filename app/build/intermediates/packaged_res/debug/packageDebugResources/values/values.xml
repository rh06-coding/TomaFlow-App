    <style name="ShapeAppearance.TomaFlow.Large" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerSize">32dp</item>
    </style>
    <style name="ShapeAppearance.TomaFlow.Medium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">24dp</item>
    </style>
    <style name="ShapeAppearance.TomaFlow.Small" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">16dp</item>
    </style>
    <style name="Theme.TomaFlow" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryVariant">@color/color_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        
        <item name="colorSecondary">@color/color_green</item>
        <item name="colorOnSecondary">@color/white</item>

        
        <item name="android:colorBackground">@color/color_background</item>
        <item name="colorSurface">@color/color_surface</item>
        <item name="colorOnSurface">@color/color_on_background</item>

        
        <item name="android:statusBarColor">@color/color_background</item>
        <item name="android:windowLightStatusBar">true</item>

        
        <item name="android:navigationBarColor">@color/color_nav_bar_bg</item>

        
        <item name="android:fontFamily">@font/manrope_regular</item>

        
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.TomaFlow.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.TomaFlow.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.TomaFlow.Large</item>

        
        <item name="bottomNavigationStyle">@style/Widget.TomaFlow.BottomNavigation</item>

    </style>
    <style name="Widget.TomaFlow.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/color_nav_bar_bg</item>
        <item name="itemIconTint">@color/selector_nav_item</item>
        <item name="itemTextColor">@color/selector_nav_item</item>
        <item name="elevation">4dp</item>
    </style>
    <style name="Widget.TomaFlow.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/color_surface</item>
        <item name="strokeColor">@color/color_border</item>
        <item name="strokeWidth">1dp</item>
    </style>
    <declare-styleable name="TimerView">
        
        <attr format="color" name="trackColor"/>
        
        <attr format="color" name="progressColor"/>
        
        <attr format="dimension" name="strokeWidth"/>
    </declare-styleable>
