<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml
    Declares the single-Activity entry point for TomaFlow.
    Permissions and additional components will be added as features are built.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.tomaflow.app">

    <!-- Foreground service permission for a persistent timer notification (future) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:label="@string/app_name"
        android:theme="@style/Theme.TomaFlow">

        <!-- ── Main / Focus screen ────────────────────── -->
        <activity
            android:exported="true"
            android:name=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── Tasks screen (stub — to be implemented) ── -->
        <activity
            android:exported="false"
            android:name=".ui.tasks.TasksActivity" />

        <!-- ── Stats screen (stub — to be implemented) ── -->
        <activity
            android:exported="false"
            android:name=".ui.stats.StatsActivity" />

        <!-- ── Rewards screen (stub — to be implemented) ─ -->
        <activity
            android:exported="false"
            android:name=".ui.rewards.RewardsActivity" />

        <!-- ── Settings screen (stub — to be implemented) ─ -->
        <activity
            android:exported="false"
            android:name=".ui.settings.SettingsActivity" />

        <!-- ── Timer Engine Service (foreground) ────────── -->
        <service
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:name=".timer.TimerEngineService">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_TYPE"
                android:value="TomaFlow needs a foreground service to maintain an accurate Pomodoro timer and display a persistent notification when the app is in the background." />
        </service>

    </application>

</manifest>
