<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml
    Declares the single-Activity entry point for TomaFlow.
    Permissions and additional components will be added as features are built.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Foreground service permission for a persistent timer notification (future) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".TomaFlowApp"
        android:label="@string/app_name"
        android:theme="@style/Theme.TomaFlow">

        <!-- ── Auth Flow ────────────────────────── -->
        <activity
            android:exported="true"
            android:name=".ui.auth.LoginActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:exported="false"
            android:name=".ui.auth.RegisterActivity" />

        <!-- ── Main / Focus screen ────────────────────── -->
        <activity
            android:exported="false"
            android:name=".MainActivity"
            android:configChanges="orientation|screenSize|keyboardHidden|smallestScreenSize|screenLayout" />

        <!-- ── Tasks screen (stub — to be implemented) ── -->
        <activity
            android:exported="false"
            android:name=".ui.tasks.TasksActivity" />

        <!-- ── Task Picker ────────────────────────────── -->
        <activity
            android:exported="false"
            android:name=".ui.tasks.TaskPickerActivity" />

        <!-- ── Stats screen (stub — to be implemented) ── -->
        <activity
            android:exported="false"
            android:name=".ui.stats.StatsActivity" />



        <!-- ── Settings screen (stub — to be implemented) ─ -->
        <activity
            android:exported="false"
            android:name=".ui.settings.SettingsActivity" />

        <!-- ── Timer Engine Service (foreground) ────────── -->
        <service
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:name=".timer.TimerEngineService">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_TYPE"
                android:value="TomaFlow needs a foreground service to maintain an accurate Pomodoro timer and display a persistent notification when the app is in the background." />
        </service>

        <!-- ── Music Picker ────────────────────────────── -->
        <activity
            android:exported="false"
            android:name=".ui.music.MusicPickerActivity" />

        <!-- ── Music Service ─────────────────────────────── -->
        <service
            android:name=".ui.music.MusicService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback"
            android:stopWithTask="true" />

    </application>

</manifest>
