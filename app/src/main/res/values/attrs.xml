<?xml version="1.0" encoding="utf-8"?>
<!--
    attrs.xml — Custom attributes for TimerView.
    Declared here so the XML editor can validate app:* attributes
    and provide auto-complete in the Layout Editor.
-->
<resources>
    <declare-styleable name="TimerView">
        <!-- Colour of the background track circle -->
        <attr name="trackColor" format="color" />
        <!-- Colour of the progress arc -->
        <attr name="progressColor" format="color" />
        <!-- Stroke width of both arcs -->
        <attr name="strokeWidth" format="dimension" />
    </declare-styleable>
</resources>
