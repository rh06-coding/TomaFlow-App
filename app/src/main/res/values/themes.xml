<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.TomaFlow" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/toma_primary</item>
        <item name="colorOnPrimary">@color/toma_on_primary</item>
        <item name="colorPrimaryContainer">@color/toma_primary_soft</item>
        <item name="colorOnPrimaryContainer">@color/toma_primary</item>
        <item name="colorSecondary">@color/toma_info</item>
        <item name="colorSurface">@color/toma_surface</item>
        <item name="android:colorBackground">@color/toma_background</item>
        <item name="android:statusBarColor">@color/toma_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">@color/toma_background</item>
        <item name="android:textColorPrimary">@color/toma_text</item>
        <item name="android:textColorSecondary">@color/toma_text_muted</item>
        <item name="materialCardViewStyle">@style/Widget.Toma.Card</item>
    </style>

    <style name="Theme.TomaFlow.Splash" parent="Theme.TomaFlow">
        <item name="android:windowBackground">@color/toma_background</item>
    </style>

    <!-- Cards -->
    <style name="Widget.Toma.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardBackgroundColor">@color/toma_surface</item>
        <item name="cardElevation">2dp</item>
        <item name="contentPadding">@dimen/card_padding</item>
    </style>

    <!-- Typography -->
    <style name="TextAppearance.Toma.Display" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/toma_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">32sp</item>
    </style>

    <style name="TextAppearance.Toma.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/toma_text</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Toma.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/toma_text_muted</item>
    </style>

    <style name="TextAppearance.Toma.Label" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/toma_text_muted</item>
        <item name="android:letterSpacing">0.2</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Toma.Brand" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/toma_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Bottom nav -->
    <style name="Widget.Toma.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.Toma.BottomNav.Indicator</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="backgroundTint">@color/toma_surface</item>
    </style>

    <style name="Widget.Toma.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/toma_primary_soft</item>
    </style>

    <!-- Buttons -->
    <style name="Widget.Toma.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/toma_primary</item>
        <item name="android:textColor">@color/toma_on_primary</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Toma.Button.Logout" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/toma_primary_soft</item>
        <item name="android:textColor">@color/toma_primary</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="icon">@drawable/ic_logout</item>
        <item name="iconTint">@color/toma_primary</item>
    </style>

    <!-- Input field -->
    <style name="Widget.Toma.TextInputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundMode">filled</item>
        <item name="boxBackgroundColor">@color/toma_surface</item>
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="hintTextColor">@color/toma_text_muted</item>
    </style>

    <!-- Slider -->
    <style name="Widget.Toma.Slider" parent="Widget.Material3.Slider">
        <item name="thumbColor">@color/toma_primary</item>
        <item name="trackColorActive">@color/toma_primary_soft</item>
        <item name="trackColorInactive">@color/toma_primary_soft</item>
        <item name="haloColor">@color/toma_primary_soft</item>
    </style>

    <style name="ShapeAppearanceOverlay.Material3.Corner.Medium" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
</resources>
