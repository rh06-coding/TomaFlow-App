<?xml version="1.0" encoding="utf-8"?>
<!--
    colors.xml — Design token colours extracted from the TomaFlow Figma prototype.

    Naming convention:
      color_*   — semantic / role-based token
      palette_* — raw colour value (avoid referencing directly in layouts)

    Prototype source colours:
      Primary (Pomodoro Red) : #AF101A
      Background             : #FDF8FD
      Surface / Card         : #FFFFFF
      On-Background (text)   : #1C1B1F
      Muted text             : #5B403D @ 70% opacity → #B35B403D
      Green (task/success)   : #1B6D24
      Timer track arc        : #FFDAD6
      Nav bar bg             : rgba(253,248,253,0.95)
-->
<resources>

    <!-- ── Palette (raw) ─────────────────────────────── -->
    <color name="palette_red_primary">#AF101A</color>
    <color name="palette_red_dark">#8B0D15</color>
    <color name="palette_red_track">#FFDAD6</color>
    <color name="palette_green">#1B6D24</color>
    <color name="palette_green_tint">#4DA03000</color><!-- rgba(160,243,153,0.30) -->
    <color name="palette_near_black">#1C1B1F</color>
    <color name="palette_warm_white">#FDF8FD</color>
    <color name="palette_surface">#FFFFFF</color>
    <color name="palette_muted_brown">#5B403D</color>

    <!-- ── Semantic tokens ──────────────────────────── -->

    <!-- Brand / accent -->
    <color name="color_primary">#AF101A</color>
    <color name="color_primary_80">#CC1A1F</color>    <!-- primary at ~80% opacity on white bg -->
    <color name="color_primary_dark">#8B0D15</color>

    <!-- Backgrounds -->
    <color name="color_background">#FDF8FD</color>
    <color name="color_surface">#FFFFFF</color>

    <!-- Text -->
    <color name="color_on_background">#1C1B1F</color>
    <color name="color_muted_text">#995B403D</color>   <!-- #5B403D @ 60% -->
    <color name="color_label_text">#CCAF101A</color>   <!-- primary @ 80% — used for sub-labels -->

    <!-- Green / success -->
    <color name="color_green">#1B6D24</color>
    <color name="color_green_tint">#4DA0F399</color>  <!-- rgba(160,243,153,0.30) -->

    <!-- Timer arc -->
    <color name="color_timer_track">#FFDAD6</color>

    <!-- Dividers / borders -->
    <color name="color_border">#1AE4BEBA</color>      <!-- rgba(228,190,186,0.10) -->

    <!-- Bottom nav -->
    <color name="color_nav_bar_bg">#F2FDF8FD</color>  <!-- rgba(253,248,253,0.95) -->
    <color name="color_nav_inactive">#737373</color>
    <color name="color_nav_active">#AF101A</color>
    <color name="color_nav_selected_bg">#F1ECF2</color>

    <!-- Generic white / black -->
    <color name="white">#FFFFFF</color>
    <color name="black">#000000</color>

</resources>
