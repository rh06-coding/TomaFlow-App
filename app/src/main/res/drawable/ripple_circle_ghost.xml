<?xml version="1.0" encoding="utf-8"?>
<!--
    ripple_circle_ghost.xml — Transparent background with a red ripple effect.
    Used for the ghost icon buttons (Reset, Skip) so they give tactile
    feedback without a persistent filled background.
-->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#20AF101A">

    <!-- Clip the ripple to a circle -->
    <item android:id="@android:id/mask">
        <shape android:shape="oval">
            <solid android:color="@color/white" />
        </shape>
    </item>

</ripple>
