<?xml version="1.0" encoding="utf-8"?>
<!-- Hạt giống — giai đoạn 0 (0–20%) -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="80dp"
    android:height="80dp"
    android:viewportWidth="80"
    android:viewportHeight="80">

    <!-- Đất -->
    <path
        android:fillColor="#8B6914"
        android:pathData="M10,62 Q40,55 70,62 L70,72 Q40,70 10,72 Z" />
    <!-- Đất lớp trên -->
    <path
        android:fillColor="#A0782A"
        android:pathData="M10,58 Q40,52 70,58 Q40,65 10,58 Z" />
    <!-- Hạt giống (ellipse cx=40,cy=54,rx=7,ry=4.5)
         Dùng path bezier thay ellipse tag:
         M cx-rx,cy  C cx-rx,cy-ry*k  cx+rx,cy-ry*k  cx+rx,cy
                     C cx+rx,cy+ry*k  cx-rx,cy+ry*k  cx-rx,cy Z
         k ≈ 0.5523 -->
    <path
        android:fillColor="#C8824A"
        android:strokeColor="#9B5E2E"
        android:strokeWidth="1.5"
        android:pathData="M33,54 C33,51.5 47,51.5 47,54 C47,56.5 33,56.5 33,54 Z" />
    <!-- Vết nứt nhỏ trên hạt -->
    <path
        android:strokeColor="#9B5E2E"
        android:strokeWidth="1.2"
        android:fillColor="#00000000"
        android:pathData="M37,54 Q40,51 43,54" />
</vector>
