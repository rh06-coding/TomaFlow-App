<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded-rect background used only to give the note card's direct child an
     outline for android:clipToOutline. With clipToOutline=true the 6dp mood
     strip (a plain rectangular ColorDrawable set in NoteAdapter) is clipped to
     these 16dp corners, so it follows the card instead of poking out. The fill
     matches the card background so it's invisible behind the strip + content. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="@color/toma_background" />
    <corners android:radius="16dp" />
</shape>
