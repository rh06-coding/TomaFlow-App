<?xml version="1.0" encoding="utf-8"?>
<!--
    selector_nav_item.xml — Colour state list for BottomNavigation icons & labels.
    Active (selected) item uses the primary Pomodoro Red; inactive items use the
    neutral grey from the prototype.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:color="@color/color_nav_active"   android:state_checked="true" />
    <item android:color="@color/color_nav_inactive" />
</selector>
