<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_badge"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="1dp"
    app:contentPadding="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/icon_bg"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_icon_chip_info">

            <ImageView
                android:id="@+id/iv_badge"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_sun"
                app:tint="@color/toma_info" />

            <ImageView
                android:id="@+id/iv_lock"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="bottom|end"
                android:src="@drawable/ic_lock"
                android:visibility="gone"
                app:tint="@color/toma_text" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_badge_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Early Bird"
            android:textColor="@color/toma_text"
            android:textStyle="bold"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tv_badge_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:text="10 Sessions before 7 AM"
            android:textAppearance="@style/TextAppearance.Toma.Body"
            android:textSize="12sp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
