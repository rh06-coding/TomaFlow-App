<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/toma_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="0dp"
        android:background="@color/toma_background">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="8dp"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/toma_primary"
            app:title="@string/leaderboard_title"
            app:titleTextColor="@color/toma_text"
            app:titleTextAppearance="@style/TextAppearance.Toma.Label" />



    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Podium Layout -->
        <LinearLayout
            android:id="@+id/layout_podium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom|center_horizontal"
            android:padding="16dp"
            android:visibility="gone">
            
            <!-- Rank 2 -->
            <LinearLayout
                android:id="@+id/podium_rank_2"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#2"
                    android:textColor="#9CA3AF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                
                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_avatar_circle">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_person"
                        app:tint="@color/toma_primary" />
                </FrameLayout>
                
                <TextView
                    android:id="@+id/tv_podium_name_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    tools:text="Name"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/toma_text"
                    android:textStyle="bold" />
                    
                <TextView
                    android:id="@+id/tv_podium_level_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Level 5"
                    android:textColor="@color/toma_text_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Rank 1 -->
            <LinearLayout
                android:id="@+id/podium_rank_1"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#1"
                    android:textColor="#F59E0B"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                
                <FrameLayout
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_avatar_circle">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_person"
                        app:tint="@color/toma_primary" />
                </FrameLayout>
                
                <TextView
                    android:id="@+id/tv_podium_name_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    tools:text="Name"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/toma_text"
                    android:textStyle="bold" />
                    
                <TextView
                    android:id="@+id/tv_podium_level_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Level 10"
                    android:textColor="@color/toma_text_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Rank 3 -->
            <LinearLayout
                android:id="@+id/podium_rank_3"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#3"
                    android:textColor="#B45309"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                
                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_avatar_circle">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_person"
                        app:tint="@color/toma_primary" />
                </FrameLayout>
                
                <TextView
                    android:id="@+id/tv_podium_name_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    tools:text="Name"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/toma_text"
                    android:textStyle="bold" />
                    
                <TextView
                    android:id="@+id/tv_podium_level_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Level 3"
                    android:textColor="@color/toma_text_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Global Tab Content -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_leaderboard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="100dp" />

        <!-- Empty State (Shown if no friends) -->
        <LinearLayout
            android:id="@+id/layout_friends_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_person"
                app:tint="@color/toma_primary_soft" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/leaderboard_empty_title"
                android:textAppearance="@style/TextAppearance.Toma.Title"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/leaderboard_empty_msg"
                android:textAppearance="@style/TextAppearance.Toma.Body"
                android:gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_friend"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="@string/btn_add_friends"
                style="@style/Widget.Toma.Button.Primary" />
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
