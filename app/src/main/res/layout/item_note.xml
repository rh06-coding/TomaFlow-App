<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/toma_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <View
            android:id="@+id/v_mood_strip"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="@color/toma_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_card_muted">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <TextView
                    android:id="@+id/tv_note_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    tools:text="Deep work session"
                    android:textColor="@color/toma_text"
                    android:textStyle="bold"
                    android:textSize="16sp" />
                    
                <TextView
                    android:id="@+id/tv_note_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="2 hrs ago"
                    android:textSize="12sp"
                    android:textColor="@color/toma_text_muted" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_note_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:maxLines="3"
                tools:text="I felt really focused and got a lot done today. The ambient music helped me stay in the zone."
                android:textAppearance="@style/TextAppearance.Toma.Body" />

            <TextView
                android:id="@+id/tv_note_mood"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_pill_muted"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                tools:text="🎯 Focused"
                android:textSize="12sp"
                android:textColor="@color/toma_text" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
