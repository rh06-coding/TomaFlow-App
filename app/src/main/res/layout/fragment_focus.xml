<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp"
        android:clipToPadding="false">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/app_name"
                android:textAppearance="@style/TextAppearance.Toma.Brand"
                android:textSize="18sp"
                android:drawableStart="@drawable/ic_tomato"
                android:drawablePadding="6dp" />
            <View
                android:id="@+id/iv_avatar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_avatar_circle" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:text="@string/focus_current"
            android:textAppearance="@style/TextAppearance.Toma.Label"
            android:textColor="@color/toma_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:text="@string/focus_title"
            android:textAppearance="@style/TextAppearance.Toma.Display"
            android:textSize="32sp" />
        <!-- Session Tab Switcher -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/session_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            app:singleSelection="true"
            app:selectionRequired="true">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tab_focus"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/focus_tab_focus"
                android:textSize="12sp"
                android:paddingHorizontal="14dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tab_short"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/focus_tab_short"
                android:textSize="12sp"
                android:paddingHorizontal="14dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_tab_long"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/focus_tab_long"
                android:textSize="12sp"
                android:paddingHorizontal="14dp" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Timer ring -->

        <FrameLayout
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_timer_ring">

            <com.tomaflow.app.ui.timer.TimerView
                android:id="@+id/timer_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/focus_time"
                    android:textColor="@color/toma_text"
                    android:textSize="64sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_session_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/focus_phase"
                    android:textAppearance="@style/TextAppearance.Toma.Label"
                    android:drawableStart="@drawable/ic_tomato"
                    android:drawablePadding="6dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="36dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageButton
                android:id="@+id/btn_reset"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_reset"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnBackground"
                android:contentDescription="Reset" />
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginHorizontal="36dp"
                android:background="@drawable/bg_play_button">
                <ImageButton
                    android:id="@+id/btn_play_pause"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_play"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/toma_on_primary"
                    android:contentDescription="Play" />
            </FrameLayout>
            <ImageButton
                android:id="@+id/btn_skip"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_skip"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="?attr/colorOnBackground"
                android:contentDescription="Skip" />
        </LinearLayout>

        <!-- Tomato Growth Widget -->
        <LinearLayout
            android:id="@+id/layout_tomato_widget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <com.tomaflow.app.ui.timer.TomatoGrowthView
                android:id="@+id/tomato_growth_view"
                android:layout_width="110dp"
                android:layout_height="110dp" />

            <TextView
                android:id="@+id/tv_tomato_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Your tomato is growing..."
                android:textColor="@color/toma_text_muted"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:textAllCaps="false" />
        </LinearLayout>


        <!-- Music card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:cardElevation="6dp"
            android:outlineAmbientShadowColor="#40000000"
            android:outlineSpotShadowColor="#40000000"
            tools:targetApi="p">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_chip_primary">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_music"
                        app:tint="@color/toma_primary" />
                </FrameLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/focus_music_title"
                        android:textColor="@color/toma_text"
                        android:textStyle="bold"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/tv_music_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/focus_music_empty"
                        android:textColor="@color/toma_text_muted" />
                </LinearLayout>
                <ImageView
                    android:id="@+id/btn_pick_music"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_chevron_right"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/focus_music_pick"
                    app:tint="@color/toma_text_muted" />
                <ImageView
                    android:id="@+id/btn_play_music"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="6dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_play"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/focus_music_play"
                    app:tint="@color/toma_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Current task card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_current_task"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            app:cardElevation="6dp"
            android:outlineAmbientShadowColor="#40000000"
            android:outlineSpotShadowColor="#40000000"
            tools:targetApi="p">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_chip_primary">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_tasks"
                        app:tint="@color/toma_primary" />
                </FrameLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_task_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Design System Review"
                        android:textColor="@color/toma_text"
                        android:textStyle="bold"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/tv_task_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Part of Project Sanctuary"
                        android:textColor="@color/toma_text_muted" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_task_pomos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_pill_primary_soft"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:layout_marginEnd="8dp"
                    android:drawableStart="@drawable/ic_tomato"
                    android:drawablePadding="4dp"
                    android:text="1"
                    android:visibility="gone"
                    android:textColor="@color/toma_primary"
                    android:textStyle="bold"
                    android:textSize="12sp" />

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/toma_primary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
