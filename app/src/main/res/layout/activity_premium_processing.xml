<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/toma_background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <FrameLayout
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="32dp">

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:indeterminateTint="@color/toma_primary" />

        <ImageView
            android:id="@+id/iv_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_star"
            app:tint="@color/toma_primary" />
            
        <ImageView
            android:id="@+id/iv_success"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check"
            android:visibility="gone"
            app:tint="@color/toma_success" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Connecting to Secure Server..."
        android:textAlignment="center"
        android:textAppearance="@style/TextAppearance.Toma.Label"
        android:textColor="@color/toma_text"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/tv_sub_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Please do not close the app"
        android:textAlignment="center"
        android:textAppearance="@style/TextAppearance.Toma.Body"
        android:textColor="@color/toma_text_muted" />

</LinearLayout>
