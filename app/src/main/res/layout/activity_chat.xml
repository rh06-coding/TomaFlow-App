<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/toma_background">

    <!-- Header Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/toma_surface"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_back"
            app:tint="@color/toma_primary"
            android:layout_marginEnd="16dp" />

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_avatar_circle">
            <TextView
                android:id="@+id/tv_header_initials"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/toma_primary"
                android:textSize="16sp"
                android:textStyle="bold" />
            <ImageView
                android:id="@+id/iv_header_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_avatar_circle"
                android:clipToOutline="true"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_header_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/friend_chat_name"
            android:textColor="@color/toma_text"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/toma_surface"
        android:elevation="8dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_share_achievement"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_share"
            app:tint="@color/toma_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginEnd="4dp"
            android:tooltipText="Share Achievement" />

        <EditText
            android:id="@+id/et_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Type a message..."
            android:background="@color/toma_surface_muted"
            android:padding="12dp"
            android:maxLines="4"
            android:inputType="textMultiLine" />

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_check"
            app:tint="@color/toma_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginStart="4dp" />
    </LinearLayout>

</LinearLayout>

