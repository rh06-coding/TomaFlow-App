<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/toma_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_received_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Received Requests"
            android:textAppearance="@style/TextAppearance.Toma.Label"
            android:textColor="@color/toma_primary"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_received_requests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_friend_request" />

        <TextView
            android:id="@+id/tv_received_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No received requests"
            android:gravity="center"
            android:padding="20dp"
            android:textColor="@color/toma_text_muted" />

        <TextView
            android:id="@+id/tv_sent_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Sent Requests"
            android:textAppearance="@style/TextAppearance.Toma.Label"
            android:textColor="@color/toma_primary"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_sent_requests"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            tools:listitem="@layout/item_friend_request" />

        <TextView
            android:id="@+id/tv_sent_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No sent requests"
            android:gravity="center"
            android:padding="20dp"
            android:textColor="@color/toma_text_muted" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
