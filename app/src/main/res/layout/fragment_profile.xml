<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/toma_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_back"
                app:tint="@color/toma_primary" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="@string/app_name"
                android:textAppearance="@style/TextAppearance.Toma.Brand" />
            <View android:layout_width="36dp" android:layout_height="36dp"
                android:background="@drawable/bg_avatar_circle" />
        </LinearLayout>

        <!-- Avatar -->
        <FrameLayout
            android:id="@+id/container_avatar"
            android:layout_width="148dp"
            android:layout_height="148dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_avatar_circle">
            <TextView
                android:id="@+id/tv_avatar_initials"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                tools:text="ER"
                android:textColor="@color/toma_primary"
                android:textSize="36sp"
                android:textStyle="bold" />
            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/bg_play_button">
                <ImageView
                    android:id="@+id/iv_badge_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_star"
                    app:tint="@color/toma_on_primary" />
            </FrameLayout>
        </FrameLayout>

        <TextView
            android:id="@+id/tv_profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            tools:text="Elena Rodriguez"
            android:textAppearance="@style/TextAppearance.Toma.Display"
            android:textSize="28sp" />

        <TextView
            android:id="@+id/tv_profile_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:text="@string/profile_role"
            android:textAppearance="@style/TextAppearance.Toma.Label"
            android:textColor="@color/toma_primary" />

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="horizontal"
            android:weightSum="3">
            <LinearLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_level_value"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    tools:text="Level 42" android:textColor="@color/toma_text"
                    android:textSize="20sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/profile_ranking" android:textAppearance="@style/TextAppearance.Toma.Label" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center_horizontal">
                <TextView
                    android:id="@+id/tv_hours_value"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    tools:text="1,240" android:textColor="@color/toma_text"
                    android:textSize="20sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/profile_hours" android:textAppearance="@style/TextAppearance.Toma.Label" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="end">
                <TextView
                    android:id="@+id/tv_streak_value"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    tools:text="98%" android:textColor="@color/toma_text"
                    android:textSize="20sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/profile_streak" android:textAppearance="@style/TextAppearance.Toma.Label" />
            </LinearLayout>
        </LinearLayout>

        <!-- Badges header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/profile_badges"
                android:textAppearance="@style/TextAppearance.Toma.Title" />
            <TextView
                android:id="@+id/btn_view_all_badges"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_view_all"
                android:textColor="@color/toma_primary"
                android:textStyle="bold"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Badge grid 2x2 -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:columnCount="2"
            android:rowCount="2"
            android:useDefaultMargins="false">

            <include layout="@layout/item_badge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp" />
            <include layout="@layout/item_badge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp" />
            <include layout="@layout/item_badge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp" />
            <include layout="@layout/item_badge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp" />
        </GridLayout>

        <!-- Cloud Sync -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card_muted"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_cloud" app:tint="@color/toma_info" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/profile_cloud"
                android:textColor="@color/toma_text"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_cloud_time"
                android:textAppearance="@style/TextAppearance.Toma.Label" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/profile_logout"
            app:iconGravity="textStart"
            style="@style/Widget.Toma.Button.Logout" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

