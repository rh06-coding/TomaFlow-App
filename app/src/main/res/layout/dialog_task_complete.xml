<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="8dp"
    android:paddingBottom="32dp"
    android:background="?attr/colorSurface">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_drag_handle" />

    <!-- Big check icon with animation -->
    <FrameLayout
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp">

        <View
            android:id="@+id/pulse_ring"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:background="@drawable/bg_pulse_ring"
            android:backgroundTint="@color/toma_success_soft"
            android:alpha="0.5" />

        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_icon_chip_success">
            <ImageView
                android:id="@+id/iv_task_icon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                app:tint="@color/toma_success"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:scaleType="fitCenter" />
        </FrameLayout>
    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/task_complete_title"
        android:textColor="?attr/colorOnSurface"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tv_dialog_sub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="28dp"
        android:text="@string/task_complete_desc"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="14sp"
        android:gravity="center" />

    <!-- Primary action button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_primary_action"
        style="@style/Widget.Toma.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/task_complete_btn" />

</LinearLayout>
