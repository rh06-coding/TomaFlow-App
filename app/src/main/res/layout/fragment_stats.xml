<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/toma_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:id="@+id/header_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">
            <ImageView
                android:id="@+id/btn_menu"
                android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_menu" app:tint="@color/toma_text" />
            <TextView
                android:id="@+id/tv_app_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="@string/app_name"
                android:textAppearance="@style/TextAppearance.Toma.Brand" />
            <TextView
                android:id="@+id/tv_screen_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:text="Stats"
                android:textColor="@color/toma_primary"
                android:textStyle="bold" />
            <View
                android:id="@+id/iv_avatar"
                android:layout_width="36dp" android:layout_height="36dp"
                android:background="@drawable/bg_avatar_circle" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/stats_performance"
            android:textAppearance="@style/TextAppearance.Toma.Label" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stats_title"
                android:textAppearance="@style/TextAppearance.Toma.Display"
                android:textSize="28sp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/range_toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_muted"
                app:singleSelection="true"
                app:selectionRequired="true">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_week"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="WEEK"
                    android:textColor="@color/toma_primary"
                    android:textStyle="bold" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_month"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="MONTH"
                    android:textColor="@color/toma_text_muted"
                    android:textStyle="bold" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <!-- Total Focus Time -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_total_focus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_focus" app:tint="@color/toma_primary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="42dp"
                    android:text="@string/stats_total"
                    android:textAppearance="@style/TextAppearance.Toma.Label" />
                <TextView
                    android:id="@+id/tv_total_focus_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="32h 14m"
                    android:textColor="@color/toma_text"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Pomodoros Completed (primary) -->
        <LinearLayout
            android:id="@+id/card_pomos_completed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_primary"
            android:orientation="vertical"
            android:padding="20dp">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_check" app:tint="@color/toma_on_primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="42dp"
                android:text="@string/stats_pomos"
                android:textColor="@color/toma_on_primary"
                android:alpha="0.85"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_pomos_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="74"
                android:textColor="@color/toma_on_primary"
                android:textSize="32sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Best day -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_best_day"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_star" app:tint="@color/toma_success" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="42dp"
                    android:text="@string/stats_best"
                    android:textAppearance="@style/TextAppearance.Toma.Label" />
                <TextView
                    android:id="@+id/tv_best_day_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Wed 8.2h"
                    android:textColor="@color/toma_text"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Chart placeholder -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card_muted"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/stats_intensity"
                    android:textAppearance="@style/TextAppearance.Toma.Title" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:drawableStart="@drawable/ic_tomato"
                    android:drawablePadding="4dp"
                    android:text="FOCUS"
                    android:textAppearance="@style/TextAppearance.Toma.Label" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• BREAKS"
                    android:textAppearance="@style/TextAppearance.Toma.Label"
                    android:textColor="@color/toma_success" />
            </LinearLayout>

            <!-- Weekly focus minutes per day -->
            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/bar_chart"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="20dp" />
        </LinearLayout>

        <!-- Session breakdown (Completed vs Failed) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card_muted"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_breakdown"
                android:textAppearance="@style/TextAppearance.Toma.Title" />

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pie_chart"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/stats_insights"
            android:textAppearance="@style/TextAppearance.Toma.Label" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_muted"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_chip_info">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_trending_up"
                    app:tint="@color/toma_info" />
            </FrameLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_peak"
                    android:textColor="@color/toma_text"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/stats_peak_desc"
                    android:textAppearance="@style/TextAppearance.Toma.Body" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
