<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/toma_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <include layout="@layout/layout_main_header" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/stats_performance"
            android:textAppearance="@style/TextAppearance.Toma.Label" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/stats_title"
                android:textAppearance="@style/TextAppearance.Toma.Display"
                android:textSize="28sp" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/range_toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_muted"
                app:singleSelection="true"
                app:selectionRequired="true">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_week"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="100dp"
                    android:text="@string/stats_tab_week"
                    android:textColor="@color/toma_primary"
                    android:textStyle="bold" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_month"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="100dp"
                    android:text="@string/stats_tab_month"
                    android:textColor="@color/toma_text_muted"
                    android:textStyle="bold" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <!-- 3 Stats Cards in Horizontal Layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:weightSum="3"
            android:baselineAligned="false">

            <!-- Total Focus Time -->
            <LinearLayout
                android:id="@+id/card_total_focus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_card_muted"
                android:orientation="vertical"
                android:padding="12dp"
                android:gravity="center">
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_focus" app:tint="@color/toma_primary" />
                <TextView
                    android:id="@+id/tv_total_focus_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    tools:text="32h"
                    android:textColor="@color/toma_text"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/stats_total"
                    android:textSize="10sp"
                    android:textAppearance="@style/TextAppearance.Toma.Label" />
            </LinearLayout>

            <!-- Pomodoros Completed -->
            <LinearLayout
                android:id="@+id/card_pomos_completed"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:background="@drawable/bg_card_primary"
                android:orientation="vertical"
                android:padding="12dp"
                android:gravity="center">
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_check" app:tint="@color/toma_on_primary" />
                <TextView
                    android:id="@+id/tv_pomos_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    tools:text="74"
                    android:textColor="@color/toma_on_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/stats_pomos"
                    android:textColor="@color/toma_on_primary"
                    android:alpha="0.85"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Best day -->
            <LinearLayout
                android:id="@+id/card_best_day"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_card_muted"
                android:orientation="vertical"
                android:padding="12dp"
                android:gravity="center">
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_star" app:tint="@color/toma_success" />
                <TextView
                    android:id="@+id/tv_best_day_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    tools:text="8.2h"
                    android:textColor="@color/toma_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/stats_best"
                    android:textSize="10sp"
                    android:textAppearance="@style/TextAppearance.Toma.Label" />
            </LinearLayout>
        </LinearLayout>

        <!-- Journal Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/stats_journal_title"
                    android:textAppearance="@style/TextAppearance.Toma.Title" />
                <TextView
                    android:id="@+id/btn_view_all_notes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_view_all"
                    android:textColor="@color/toma_primary"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginEnd="12dp"
                    android:background="?attr/selectableItemBackground"
                    android:padding="6dp"/>
                <ImageView
                    android:id="@+id/btn_add_note"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:src="@drawable/ic_add"
                    app:tint="@color/toma_primary" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_journal_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_muted"
                android:padding="20dp"
                android:gravity="center"
                android:text="@string/stats_journal_empty"
                android:textAppearance="@style/TextAppearance.Toma.Body" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_notes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="2"
                tools:listitem="@layout/item_note" />
        </LinearLayout>

        <!-- Chart placeholder -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card_muted"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/stats_intensity"
                    android:textAppearance="@style/TextAppearance.Toma.Title" />
                    
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    
                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_tomato" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="10dp"
                        android:text="@string/stats_focus_label"
                        android:textAppearance="@style/TextAppearance.Toma.Label" />
                        
                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_icon_chip_success" />
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/stats_breaks_label"
                        android:textAppearance="@style/TextAppearance.Toma.Label"
                        android:textColor="@color/toma_success" />
                </LinearLayout>
            </LinearLayout>

            <!-- Weekly focus minutes per day -->
            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/bar_chart"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="20dp" />
        </LinearLayout>

        <!-- Session breakdown (Completed vs Failed) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card_muted"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stats_breakdown"
                android:textAppearance="@style/TextAppearance.Toma.Brand" />

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pie_chart"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/stats_insights"
            android:textAppearance="@style/TextAppearance.Toma.Label" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_card_muted"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_icon_chip_info">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_trending_up"
                    app:tint="@color/toma_info" />
            </FrameLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stats_peak"
                    android:textColor="@color/toma_text"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/stats_peak_desc"
                    android:textAppearance="@style/TextAppearance.Toma.Body" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

